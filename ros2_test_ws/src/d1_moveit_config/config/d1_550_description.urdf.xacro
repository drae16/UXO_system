<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="d1_550_description">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import d1_550_description urdf file -->
    <xacro:include filename="$(find d1_550_description)/urdf/d1_550_description.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="d1_550_description.ros2_control.xacro" />


    <xacro:d1_550_description_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
